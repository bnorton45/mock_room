<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:MockRoom.ViewModels"
        xmlns:ctrl="clr-namespace:MockRoom.Controls"
        xmlns:rooms="clr-namespace:MockRoom.Core.Rooms;assembly=MockRoom.Core"
        x:Class="MockRoom.MainWindow"
        x:Name="Root"
        x:DataType="vm:RoomEditorViewModel"
        Title="MockRoom"
        Width="1280" Height="720"
        MinWidth="900" MinHeight="600">

    <DockPanel>
        <!-- Title bar -->
        <Border DockPanel.Dock="Top" Background="#202830" Padding="12,8">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" Text="MockRoom" FontSize="18" FontWeight="SemiBold"
                           Foreground="White" VerticalAlignment="Center" />
                <TextBlock Grid.Column="1" Name="StatusText" FontSize="12"
                           Foreground="#E0A0A0" VerticalAlignment="Center" />
            </Grid>
        </Border>

        <!-- Left tool panel -->
        <Border DockPanel.Dock="Left" Width="300" Background="#1A1F25" Padding="14">
            <ScrollViewer>
                <StackPanel Spacing="16">

                    <!-- File -->
                    <StackPanel Spacing="6">
                        <TextBlock Text="FILE" FontSize="11" Foreground="#7A828C" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button x:Name="OpenButton" Content="Open" />
                            <Button x:Name="SaveButton" Content="Save" />
                        </StackPanel>
                    </StackPanel>

                    <!-- Units -->
                    <StackPanel Spacing="6">
                        <TextBlock Text="UNITS" FontSize="11" Foreground="#7A828C" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <RadioButton Content="Metric" GroupName="units"
                                         IsChecked="{Binding IsMetric}" Command="{Binding SetMetricCommand}" />
                            <RadioButton Content="Imperial" GroupName="units"
                                         IsChecked="{Binding IsImperial}" Command="{Binding SetImperialCommand}" />
                        </StackPanel>
                    </StackPanel>

                    <!-- Room dimensions -->
                    <StackPanel Spacing="6">
                        <TextBlock Text="ROOM DIMENSIONS" FontSize="11" Foreground="#7A828C" />
                        <TextBlock Text="{Binding UnitHint}" FontSize="10" Foreground="#5E666F"
                                   TextWrapping="Wrap" />
                        <Grid ColumnDefinitions="60,*" RowDefinitions="Auto,Auto,Auto">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Width" VerticalAlignment="Center" Margin="0,0,0,6" />
                            <TextBox  Grid.Row="0" Grid.Column="1" Text="{Binding WidthText}" Margin="0,0,0,6" />
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Length" VerticalAlignment="Center" Margin="0,0,0,6" />
                            <TextBox  Grid.Row="1" Grid.Column="1" Text="{Binding LengthText}" Margin="0,0,0,6" />
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Height" VerticalAlignment="Center" />
                            <TextBox  Grid.Row="2" Grid.Column="1" Text="{Binding HeightText}" />
                        </Grid>
                        <Button Content="Apply dimensions" HorizontalAlignment="Stretch"
                                Command="{Binding ApplyDimensionsCommand}" />
                        <TextBlock Text="{Binding DimensionError}" Foreground="#E06C6C" FontSize="11"
                                   TextWrapping="Wrap" IsVisible="{Binding HasDimensionError}" />
                    </StackPanel>

                    <!-- Add a box -->
                    <StackPanel Spacing="6">
                        <TextBlock Text="ADD A BOX" FontSize="11" Foreground="#7A828C" />
                        <TextBox Text="{Binding NewItemName}" Watermark="Name (e.g. Bed, Desk)" />
                        <Button Content="Add box" HorizontalAlignment="Stretch"
                                Command="{Binding AddBoxCommand}" />
                        <TextBlock Text="Adds a 1 m box you can rename, resize, and drag."
                                   FontSize="10" Foreground="#5E666F" TextWrapping="Wrap" />
                    </StackPanel>

                    <!-- Openings: doors, closet doors, windows -->
                    <StackPanel Spacing="6">
                        <TextBlock Text="OPENINGS" FontSize="11" Foreground="#7A828C" />
                        <ComboBox HorizontalAlignment="Stretch"
                                  ItemsSource="{Binding WallSides}"
                                  SelectedItem="{Binding OpeningWall}" />
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Button Content="+ Door" Command="{Binding AddDoorCommand}" />
                            <Button Content="+ Closet" Command="{Binding AddClosetDoorCommand}" />
                            <Button Content="+ Window" Command="{Binding AddWindowCommand}" />
                        </StackPanel>
                        <TextBlock Text="Adds an opening on the selected wall. Doors and closets swing 90° into the room."
                                   FontSize="10" Foreground="#5E666F" TextWrapping="Wrap" />

                        <ListBox MaxHeight="120"
                                 ItemsSource="{Binding Openings}"
                                 SelectedItem="{Binding SelectedOpening, Mode=TwoWay}">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="rooms:WallOpening">
                                    <TextBlock>
                                        <Run Text="{Binding Kind}" /><Run Text=" · " /><Run Text="{Binding Wall}" />
                                    </TextBlock>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Grid ColumnDefinitions="70,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                              IsEnabled="{Binding HasOpeningSelection}">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Offset" VerticalAlignment="Center" Margin="0,0,0,6"
                                       ToolTip.Tip="Distance from the wall start to the near edge of the opening." />
                            <TextBox  Grid.Row="0" Grid.Column="1" Text="{Binding OpeningOffsetText}" Margin="0,0,0,6" />
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Width" VerticalAlignment="Center" Margin="0,0,0,6" />
                            <TextBox  Grid.Row="1" Grid.Column="1" Text="{Binding OpeningWidthText}" Margin="0,0,0,6" />
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Height" VerticalAlignment="Center" Margin="0,0,0,6" />
                            <TextBox  Grid.Row="2" Grid.Column="1" Text="{Binding OpeningHeightText}" Margin="0,0,0,6" />
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Sill" VerticalAlignment="Center" Margin="0,0,0,6"
                                       ToolTip.Tip="Distance from the floor to the bottom of the window opening." />
                            <TextBox  Grid.Row="3" Grid.Column="1" Text="{Binding OpeningSillText}" Margin="0,0,0,6"
                                      IsEnabled="{Binding OpeningIsWindow}" />
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Hinge" VerticalAlignment="Center"
                                       IsVisible="{Binding OpeningHasHinge}" />
                            <ComboBox Grid.Row="4" Grid.Column="1" HorizontalAlignment="Stretch"
                                      ItemsSource="{Binding HingeSides}"
                                      SelectedItem="{Binding OpeningHinge}"
                                      IsVisible="{Binding OpeningHasHinge}" />
                        </Grid>

                        <!-- Frame widths: doors get top/left/right; windows get all four sides -->
                        <StackPanel Spacing="6" IsVisible="{Binding OpeningHasFrame}">
                            <TextBlock Text="FRAME (per side)" FontSize="10" Foreground="#7A828C" />
                            <Grid ColumnDefinitions="50,*,50,*" RowDefinitions="Auto,Auto">
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Top" VerticalAlignment="Center" Margin="0,0,0,6" />
                                <TextBox  Grid.Row="0" Grid.Column="1" Text="{Binding FrameTopText}" Margin="0,0,6,6" />
                                <TextBlock Grid.Row="0" Grid.Column="2" Text="Bottom" VerticalAlignment="Center" Margin="0,0,0,6"
                                           IsVisible="{Binding OpeningIsWindow}" />
                                <TextBox  Grid.Row="0" Grid.Column="3" Text="{Binding FrameBottomText}" Margin="0,0,0,6"
                                          IsVisible="{Binding OpeningIsWindow}" />
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Left" VerticalAlignment="Center" />
                                <TextBox  Grid.Row="1" Grid.Column="1" Text="{Binding FrameLeftText}" Margin="0,0,6,0" />
                                <TextBlock Grid.Row="1" Grid.Column="2" Text="Right" VerticalAlignment="Center" />
                                <TextBox  Grid.Row="1" Grid.Column="3" Text="{Binding FrameRightText}" />
                            </Grid>
                        </StackPanel>
                        <Button Content="Apply opening" HorizontalAlignment="Stretch"
                                IsEnabled="{Binding HasOpeningSelection}"
                                Command="{Binding ApplyOpeningCommand}" />
                        <TextBlock Text="{Binding OpeningError}" Foreground="#E06C6C" FontSize="11"
                                   TextWrapping="Wrap" IsVisible="{Binding HasOpeningError}" />
                        <Button Content="Remove opening" HorizontalAlignment="Stretch"
                                Command="{Binding RemoveOpeningCommand}" />
                    </StackPanel>

                    <!-- Placement -->
                    <StackPanel Spacing="6">
                        <TextBlock Text="PLACEMENT" FontSize="11" Foreground="#7A828C" />
                        <CheckBox Content="Snap to grid" IsChecked="{Binding SnapEnabled}" />
                        <TextBlock Text="Drag items in the plan to move them." FontSize="10"
                                   Foreground="#5E666F" TextWrapping="Wrap" />
                    </StackPanel>

                    <!-- Item size / rotation — only when an item is selected -->
                    <StackPanel Spacing="6" IsVisible="{Binding HasItemSelection}">
                        <TextBlock Text="SELECTED ITEM" FontSize="11" Foreground="#7A828C" />
                        <TextBlock Text="{Binding SelectedItem.Name, FallbackValue='', TargetNullValue=''}"
                                   Foreground="#C9D1D9" />

                        <Grid ColumnDefinitions="70,*" RowDefinitions="Auto,Auto,Auto,Auto">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Width" VerticalAlignment="Center" Margin="0,0,0,6" />
                            <TextBox  Grid.Row="0" Grid.Column="1" Text="{Binding ItemWidthText}" Margin="0,0,0,6" />
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Depth" VerticalAlignment="Center" Margin="0,0,0,6" />
                            <TextBox  Grid.Row="1" Grid.Column="1" Text="{Binding ItemDepthText}" Margin="0,0,0,6" />
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Height" VerticalAlignment="Center" Margin="0,0,0,6" />
                            <TextBox  Grid.Row="2" Grid.Column="1" Text="{Binding ItemHeightText}" Margin="0,0,0,6" />
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Rotate°" VerticalAlignment="Center" />
                            <TextBox  Grid.Row="3" Grid.Column="1" Text="{Binding ItemRotationText}" />
                        </Grid>

                        <Button Content="Apply size" HorizontalAlignment="Stretch"
                                Command="{Binding ApplyItemCommand}" />
                        <TextBlock Text="{Binding ItemError}" Foreground="#E06C6C" FontSize="11"
                                   TextWrapping="Wrap" IsVisible="{Binding HasItemError}" />

                        <TextBlock Text="MATERIAL" FontSize="10" Foreground="#7A828C" Margin="0,4,0,0" />
                        <Grid ColumnDefinitions="68,*,32" RowDefinitions="Auto,Auto">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Metallic"  VerticalAlignment="Center" FontSize="11" Margin="0,0,0,4" />
                            <Slider   Grid.Row="0" Grid.Column="1" Minimum="0" Maximum="1"
                                      Value="{Binding ItemMetallic, Mode=TwoWay}" Margin="4,0,4,4" />
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="{Binding ItemMetallic, StringFormat={}{0:0.00}}"
                                       FontSize="10" Foreground="#9AA0A6" VerticalAlignment="Center" Margin="0,0,0,4" />
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Roughness" VerticalAlignment="Center" FontSize="11" />
                            <Slider   Grid.Row="1" Grid.Column="1" Minimum="0" Maximum="1"
                                      Value="{Binding ItemRoughness, Mode=TwoWay}" Margin="4,0,4,0" />
                            <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding ItemRoughness, StringFormat={}{0:0.00}}"
                                       FontSize="10" Foreground="#9AA0A6" VerticalAlignment="Center" />
                        </Grid>

                        <Button Content="Remove item" HorizontalAlignment="Stretch"
                                Command="{Binding RemoveSelectedCommand}" />
                    </StackPanel>

                    <!-- Paint: unified color picker for any selected surface or item -->
                    <StackPanel Spacing="6" IsVisible="{Binding HasPaintTarget}">
                        <TextBlock Text="PAINT" FontSize="11" Foreground="#7A828C" />
                        <TextBlock Text="{Binding SelectedTargetLabel}" Foreground="#C9D1D9" FontSize="12" />

                        <!-- Color swatch button: shows current color, click to toggle wheel -->
                        <Button Command="{Binding ToggleColorPickerCommand}"
                                Padding="0" CornerRadius="4" HorizontalAlignment="Left"
                                ToolTip.Tip="Click to open color wheel">
                            <Border Width="80" Height="32" CornerRadius="4"
                                    BorderThickness="1" BorderBrush="#444C56">
                                <Border.Background>
                                    <SolidColorBrush Color="{Binding SelectedColor}" />
                                </Border.Background>
                            </Border>
                        </Button>

                        <!-- Color wheel — appears when IsColorPickerOpen -->
                        <Border IsVisible="{Binding IsColorPickerOpen}"
                                Background="#202830" CornerRadius="6" Padding="8">
                            <ColorView Color="{Binding SelectedColor, Mode=TwoWay}"
                                       ColorSpectrumShape="Ring"
                                       IsAlphaEnabled="False"
                                       IsAlphaVisible="False"
                                       HorizontalAlignment="Stretch" />
                        </Border>

                        <TextBlock Text="Click the floor, a wall, a door, window, or item to select it."
                                   FontSize="10" Foreground="#5E666F" TextWrapping="Wrap"
                                   IsVisible="{Binding !HasPaintTarget}" />
                    </StackPanel>

                    <!-- Hint when nothing is selected -->
                    <TextBlock IsVisible="{Binding !HasPaintTarget}"
                               Text="Click the floor, a wall, a door, a window, or a box to select and paint it."
                               FontSize="10" Foreground="#5E666F" TextWrapping="Wrap" />

                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Center: switchable 2D floor plan / 3D viewport with usable-area readout -->
        <DockPanel Background="#11151A">

            <!-- View toggle -->
            <Border DockPanel.Dock="Top" Background="#161B21" Padding="10,6">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <RadioButton Content="2D plan" GroupName="view" IsChecked="{Binding Is2D}" />
                    <RadioButton Content="3D view" GroupName="view" IsChecked="{Binding Is3D}" />
                </StackPanel>
            </Border>

            <Grid>
                <ctrl:FloorPlan2DControl x:Name="Plan"
                    IsVisible="{Binding Is2D}"
                    Room="{Binding Room}"
                    RenderVersion="{Binding RenderVersion}"
                    SpaceReport="{Binding LastReport}"
                    SelectedTarget="{Binding SelectedTarget, Mode=TwoWay}" />

                <ctrl:Viewport3DControl x:Name="View3D"
                    IsVisible="{Binding Is3D}"
                    Room="{Binding Room}"
                    RenderVersion="{Binding RenderVersion}"
                    SpaceReport="{Binding LastReport}"
                    SelectedTarget="{Binding SelectedTarget, Mode=TwoWay}"
                    CameraMode="{Binding CameraMode}"
                    EyeHeight="{Binding EyeHeightMeters, Mode=TwoWay}"
                    ViewpointX="{Binding ViewpointX}"
                    ViewpointZ="{Binding ViewpointZ}"
                    ViewpointYaw="{Binding ViewpointYaw}"
                    ViewpointVersion="{Binding ViewpointVersion}" />

                <!-- Transparent input layer: GL surfaces aren't hit-testable, so this
                     forwards drag/zoom to the viewport. -->
                <Border x:Name="View3DInput" IsVisible="{Binding Is3D}" Background="Transparent" />

                <!-- Item name badges rendered above the 3D scene. -->
                <ctrl:ItemLabels3DControl x:Name="Labels3D"
                    IsVisible="{Binding Is3D}"
                    IsHitTestVisible="False"
                    Room="{Binding Room}"
                    RenderVersion="{Binding RenderVersion}" />

                <!-- Usable-space HUD (upper-right) -->
                <Border HorizontalAlignment="Right" VerticalAlignment="Top" Margin="16"
                        Background="#CC202830" CornerRadius="6" Padding="12,10">
                    <StackPanel Spacing="2">
                        <TextBlock Text="USABLE SPACE" FontSize="10" Foreground="#7A828C" />
                        <TextBlock Text="{Binding FreeAreaText}" FontSize="22" FontWeight="SemiBold"
                                   Foreground="#5AB0FF" />
                        <TextBlock FontSize="10" Foreground="#9AA0A6">
                            <Run Text="of " /><Run Text="{Binding TotalAreaText}" /><Run Text=" total" />
                        </TextBlock>
                        <TextBlock FontSize="10" Foreground="#9AA0A6">
                            <Run Text="used: " /><Run Text="{Binding UsedAreaText}" />
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- 3D camera controls (lower-left, only in 3D) -->
                <Border IsVisible="{Binding Is3D}" HorizontalAlignment="Left" VerticalAlignment="Bottom"
                        Margin="16" Background="#CC202830" CornerRadius="6" Padding="12,10">
                    <StackPanel Spacing="8" Width="220">
                        <TextBlock Text="CAMERA" FontSize="10" Foreground="#7A828C" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <RadioButton Content="First-person" GroupName="cam"
                                         IsChecked="{Binding IsFirstPerson}" Command="{Binding SetFirstPersonCommand}" />
                            <RadioButton Content="Orbit" GroupName="cam"
                                         IsChecked="{Binding IsOrbit}" Command="{Binding SetOrbitCommand}" />
                        </StackPanel>
                        <TextBlock Text="Eye height" FontSize="10" Foreground="#9AA0A6" />
                        <Slider Minimum="0.1" Maximum="{Binding EyeHeightMaxMeters}"
                                Value="{Binding EyeHeightMeters}" IsEnabled="{Binding IsFirstPerson}" />
                        <StackPanel IsVisible="{Binding IsFirstPerson}" Spacing="4">
                            <TextBlock Text="VIEWPOINT" FontSize="10" Foreground="#9AA0A6" />
                            <TextBlock Text="{Binding ViewpointLabel}" FontSize="10" Foreground="#C9D1D9" />
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <Button Content="◀ Prev" Command="{Binding PrevViewpointCommand}"
                                        Padding="8,3" FontSize="11" />
                                <Button Content="Next ▶" Command="{Binding NextViewpointCommand}"
                                        Padding="8,3" FontSize="11" />
                            </StackPanel>
                        </StackPanel>
                        <TextBlock Text="Drag to look · wheel to zoom (orbit) · click to select and paint."
                                   FontSize="10" Foreground="#5E666F" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>
        </DockPanel>
    </DockPanel>
</Window>
